# Copy to .env for local pipeline runs (.env is git-ignored). On HF Spaces /
# GitHub Actions these are set as secrets, never committed.

# Anthropic — classify/relevance (Phase 2), Q&A answers (Phase 5), LLM judge (Phase 6)
ANTHROPIC_API_KEY=

# --- Cheap offline LLM steps: classify-confirm + relevance/intro notes (ADR-0002) ---
# Provider switch for the THREE cheap pipeline calls ONLY (not Q&A — that stays on
# Anthropic via QA_MODEL). Default 'anthropic' = unchanged behavior. Set 'hf' to route
# them through HF Inference Providers (PRO included credits), authenticated by HF_TOKEN
# or your `hf auth login`. The swap is eval-gated (eval/relevance_set.json) — flip only
# if per-area precision holds. With LLM_PROVIDER=hf you MUST set CLASSIFY_MODEL/NOTE_MODEL
# to HF model ids (the claude defaults won't serve there).
# LLM_PROVIDER=anthropic
# CLASSIFY_MODEL=claude-haiku-4-5-20251001   # hf e.g. meta-llama/Llama-3.1-8B-Instruct
# NOTE_MODEL=claude-haiku-4-5-20251001       # hf e.g. meta-llama/Llama-3.1-8B-Instruct
# HF_INFERENCE_PROVIDER=auto                 # which upstream provider HF routes to

# NCBI E-utilities key — optional; lifts PubMed rate limit 3 -> 10 req/s (Phase 0)
NCBI_API_KEY=

# Embeddings — LOCAL by default (no key needed). Override the model if desired;
# changing it requires re-embedding the whole corpus (Phase 1).
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Durable corpus store — HF Dataset repo the pipeline pushes to and the Space
# pulls from (Phase 1 persistence decision). HF_TOKEN needs write access.
# CORPUS_HF_DATASET=anne-voigt/bcc-lit-corpus
# HF_TOKEN=

# Transactional email — Phase 3. Default provider is Resend (set EMAIL_PROVIDER
# to "postmark" to switch). Send from an address on a domain/subdomain you've
# verified with the provider (SPF/DKIM). A dedicated SENDING SUBDOMAIN is
# recommended (e.g. send.your-domain.com) so it never collides with existing
# inbound email routing on the root domain (e.g. Cloudflare Email Routing).
EMAIL_PROVIDER=resend
EMAIL_SENDER=BCC Lit Digest <digest@send.your-domain.com>
RESEND_API_KEY=
# POSTMARK_SERVER_TOKEN=
# TEST_EMAIL=you@example.com          # used by: run_weekly --test-send "$TEST_EMAIL"

# Live-send gate — the digest stays DRY-RUN (writes out/digest_<date>.html and
# sends nothing) unless this is exactly "1".
SEND_LIVE=0
